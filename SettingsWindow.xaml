<Window x:Class="BF_STT.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BF_STT"
        mc:Ignorable="d"
        Title="Settings"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Width="600"
        Height="760"
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#333333"/>
        <SolidColorBrush x:Key="CardBrush" Color="#2B2B2B"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#454545"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#AAAAAA"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#007ACC"/>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderThickness="1"
                                BorderBrush="#444444">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#444444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="#007ACC" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="14" Height="14" Fill="White" Stroke="#007ACC" StrokeThickness="2">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.5" Color="Black"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="#3A3A3A" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarLineButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" CornerRadius="4"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="MinWidth" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#595959" CornerRadius="4" Margin="2,1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Thumb">
                                <Border Background="#7A7A7A" CornerRadius="4" Margin="2,1"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Background="{TemplateBinding Background}" Width="{TemplateBinding Width}">
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarLineButtonStyle}" Command="ScrollBar.PageUpCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarLineButtonStyle}" Command="ScrollBar.PageDownCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Background="{TemplateBinding Background}" Height="{TemplateBinding Height}">
                <Track x:Name="PART_Track" IsDirectionReversed="False" Orientation="Horizontal">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarLineButtonStyle}" Command="ScrollBar.PageLeftCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarLineButtonStyle}" Command="ScrollBar.PageRightCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="12"/>
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabScrollViewerStyle" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="CanContentScroll" Value="False"/>
            <Setter Property="Padding" Value="4,0,6,0"/>
        </Style>

        <ControlTemplate x:Key="ModernComboBoxToggleButton" TargetType="ToggleButton">
            <Border x:Name="Border" CornerRadius="4" BorderThickness="1" BorderBrush="#3A3A3C" Background="#252526">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="20" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="1" Background="Transparent">
                        <Path x:Name="Arrow" Fill="#AAAAAA" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L3.5,4 L7,0 Z"/>
                    </Border>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#2D2D30" />
                    <Setter TargetName="Border" Property="BorderBrush" Value="#4A4A4C" />
                    <Setter TargetName="Arrow" Property="Fill" Value="White" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#2D2D30" />
                    <Setter TargetName="Border" Property="BorderBrush" Value="#007ACC" />
                    <Setter TargetName="Arrow" Property="Fill" Value="#007ACC" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#252526" />
            <Setter Property="BorderBrush" Value="#3A3A3C" />
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Padding" Value="8,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#252526"/>
                        <Setter Property="Foreground" Value="#CCCCCC"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}" Margin="2,1">
                                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#333333"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#007ACC"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Template="{StaticResource ModernComboBoxToggleButton}"
                                          Grid.Column="2" Focusable="false"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="8,0,20,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border x:Name="DropDownBorder" MaxHeight="200" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}" Background="#252526" BorderThickness="1" BorderBrush="#3A3A3C" CornerRadius="4" Margin="0,4,0,0">
                                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}"
                                CornerRadius="8,8,0,0" Padding="{TemplateBinding Padding}" Margin="0,0,2,0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#333333"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1E1E1E"
            CornerRadius="12"
            BorderThickness="1"
            BorderBrush="#333333"
            MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="10,5,10,15">
                <Button Width="32"
                        Height="32"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        ToolTip="Kiểm tra phiên bản mới"
                        Background="#333333"
                        Click="CheckUpdateButtonClick">
                    <TextBlock Text="&#x1F504;" FontSize="16" Margin="0,-2,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
                <TextBlock Text="Settings"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                <Button Width="32"
                        Height="32"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        ToolTip="Mở thư mục chứa file cấu hình"
                        Background="#333333"
                        Click="OpenConfigFolderButton_Click">
                    <TextBlock Text="&#x1F4C2;" FontSize="16" Margin="0,-2,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
            </Grid>

            <TabControl Grid.Row="1" Margin="0,0,0,15">
                <TabItem Header="&#x2699; General">
                    <Border Background="{StaticResource PanelBrush}" CornerRadius="0,8,8,8" Padding="18,16">
                        <ScrollViewer Style="{StaticResource TabScrollViewerStyle}">
                            <StackPanel MaxWidth="520">
                                <Border Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Input &amp; Hotkeys" Foreground="White" FontSize="14" Margin="0,0,0,12" FontWeight="SemiBold"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Microphone" Style="{StaticResource SectionLabelStyle}"/>
                                                <ComboBox x:Name="MicrophoneComboBox" Height="30" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Hotkey" Style="{StaticResource SectionLabelStyle}"/>
                                                <ComboBox x:Name="HotkeyComboBox" Height="30" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="TTS" Style="{StaticResource SectionLabelStyle}"/>
                                                <ComboBox x:Name="TtsHotkeyComboBox" Height="30" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="6">
                                                <TextBlock Text="Stop &amp; Send" Style="{StaticResource SectionLabelStyle}" ToolTip="Stop &amp; Send Hotkey"/>
                                                <ComboBox x:Name="StopAndSendHotkeyComboBox" Height="30" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Behavior" Foreground="White" FontSize="14" Margin="0,0,0,12" FontWeight="SemiBold"/>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Language" Style="{StaticResource SectionLabelStyle}"/>
                                                <ComboBox x:Name="LanguageComboBox" Height="30">
                                                    <ComboBoxItem Content="vi" Tag="vi"/>
                                                    <ComboBoxItem Content="en" Tag="en"/>
                                                    <ComboBoxItem Content="ja" Tag="ja"/>
                                                    <ComboBoxItem Content="ko" Tag="ko"/>
                                                    <ComboBoxItem Content="zh" Tag="zh"/>
                                                    <ComboBoxItem Content="fr" Tag="fr"/>
                                                    <ComboBoxItem Content="de" Tag="de"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="History Limit" Style="{StaticResource SectionLabelStyle}"/>
                                                <TextBox x:Name="MaxHistoryLimitTextBox" Height="30" Padding="5,2" VerticalContentAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                        <CheckBox x:Name="TestModeCheckBox" Content="Test Mode (Run both APIs simultaneously)" Margin="0,0,0,8"/>
                                        <CheckBox x:Name="AutoCheckUpdateCheckBox" Content="Tự động kiểm tra phiên bản mới" Margin="0,0,0,8"/>
                                        <CheckBox x:Name="NoiseSuppressionCheckBox" Content="Noise Suppression (RNNoise)" Margin="0,0,0,8"/>
                                        <CheckBox x:Name="StartWithWindowsCheckBox" Content="Start with Windows"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </TabItem>

                <TabItem Header="STT Keys">
                    <Border Background="{StaticResource PanelBrush}" CornerRadius="0,8,8,8" Padding="18,16">
                        <ScrollViewer Style="{StaticResource TabScrollViewerStyle}">
                            <Grid MaxWidth="520">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Deepgram" Foreground="White" FontSize="13" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                        <TextBlock Text="API Key" Style="{StaticResource SectionLabelStyle}"/>
                                        <TextBox x:Name="ApiKeyTextBox" FontSize="11" Padding="6"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Speechmatics" Foreground="White" FontSize="13" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                        <TextBlock Text="API Key" Style="{StaticResource SectionLabelStyle}"/>
                                        <TextBox x:Name="SpeechmaticsApiKeyTextBox" FontSize="11" Padding="6"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Soniox" Foreground="White" FontSize="13" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                        <TextBlock Text="API Key" Style="{StaticResource SectionLabelStyle}"/>
                                        <TextBox x:Name="SonioxApiKeyTextBox" FontSize="11" Padding="6"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="OpenAI" Foreground="White" FontSize="13" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                        <TextBlock Text="API Key" Style="{StaticResource SectionLabelStyle}"/>
                                        <TextBox x:Name="OpenAIApiKeyTextBox" FontSize="11" Padding="6"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="ElevenLabs" Foreground="White" FontSize="13" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                        <TextBlock Text="API Key" Style="{StaticResource SectionLabelStyle}"/>
                                        <TextBox x:Name="ElevenLabsApiKeyTextBox" FontSize="11" Padding="6"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Google" Foreground="White" FontSize="13" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                        <TextBlock Text="API Key" Style="{StaticResource SectionLabelStyle}"/>
                                        <TextBox x:Name="GoogleApiKeyTextBox" FontSize="11" Padding="6"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="AssemblyAI" Foreground="White" FontSize="13" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                        <TextBlock Text="API Key" Style="{StaticResource SectionLabelStyle}"/>
                                        <TextBox x:Name="AssemblyAIApiKeyTextBox" FontSize="11" Padding="6"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="3" Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Azure" Foreground="White" FontSize="13" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                        <TextBlock Text="API Key" Style="{StaticResource SectionLabelStyle}"/>
                                        <TextBox x:Name="AzureApiKeyTextBox" FontSize="11" Padding="6"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="4" Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Azure Region" Foreground="White" FontSize="13" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                        <TextBlock Text="Region" Style="{StaticResource SectionLabelStyle}"/>
                                        <TextBox x:Name="AzureRegionTextBox" FontSize="11" Padding="6" ToolTip="Region (e.g. eastus)"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </TabItem>

                <TabItem Header="TTS Keys">
                    <Border Background="{StaticResource PanelBrush}" CornerRadius="0,8,8,8" Padding="18,16">
                        <ScrollViewer Style="{StaticResource TabScrollViewerStyle}">
                            <StackPanel MaxWidth="520">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Active Provider" Foreground="White" FontSize="13" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                            <TextBlock Text="Provider" Style="{StaticResource SectionLabelStyle}"/>
                                            <ComboBox x:Name="TtsProviderComboBox" Height="30"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Availability" Foreground="White" FontSize="13" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                            <TextBlock Text="Unsupported" Style="{StaticResource SectionLabelStyle}"/>
                                            <TextBox Text="AssemblyAI voice-agent only" IsReadOnly="True" FontSize="11" Padding="6"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="OpenAI" Foreground="White" FontSize="13" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                            <TextBlock Text="API Key" Style="{StaticResource SectionLabelStyle}"/>
                                            <TextBox x:Name="OpenAITtsApiKeyTextBox" FontSize="11" Padding="6"/>
                                            <TextBlock Text="Voice" Style="{StaticResource SectionLabelStyle}" Margin="0,8,0,4"/>
                                            <TextBox x:Name="OpenAITtsVoiceTextBox" FontSize="11" Padding="6"/>
                                            <TextBlock Text="{Binding Value, ElementName=OpenAIVolumeSlider, StringFormat='Volume: {0:0}%'}" Style="{StaticResource SectionLabelStyle}" Margin="0,8,0,4"/>
                                            <Slider x:Name="OpenAIVolumeSlider" Minimum="0" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="False" Value="100"/>
                                            <TextBlock Text="{Binding Value, ElementName=OpenAIRateSlider, StringFormat='Speed: {0:0}%'}" Style="{StaticResource SectionLabelStyle}" Margin="0,8,0,4"/>
                                            <Slider x:Name="OpenAIRateSlider" Minimum="50" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="False" Value="100"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="ElevenLabs" Foreground="White" FontSize="13" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                            <TextBlock Text="API Key" Style="{StaticResource SectionLabelStyle}"/>
                                            <TextBox x:Name="ElevenLabsTtsApiKeyTextBox" FontSize="11" Padding="6"/>
                                            <TextBlock Text="Voice ID" Style="{StaticResource SectionLabelStyle}" Margin="0,8,0,4"/>
                                            <TextBox x:Name="ElevenLabsTtsVoiceTextBox" FontSize="11" Padding="6"
                                                     ToolTip="Use a Voice ID from My Voices or Default voices. Voice Library voices may be blocked by your ElevenLabs plan/API access."/>
                                            <TextBlock Text="{Binding Value, ElementName=ElevenLabsVolumeSlider, StringFormat='Volume: {0:0}%'}" Style="{StaticResource SectionLabelStyle}" Margin="0,8,0,4"/>
                                            <Slider x:Name="ElevenLabsVolumeSlider" Minimum="0" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="False" Value="100"/>
                                            <TextBlock Text="{Binding Value, ElementName=ElevenLabsRateSlider, StringFormat='Speed: {0:0}%'}" Style="{StaticResource SectionLabelStyle}" Margin="0,8,0,4"/>
                                            <Slider x:Name="ElevenLabsRateSlider" Minimum="50" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="False" Value="100"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Deepgram" Foreground="White" FontSize="13" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                            <TextBlock Text="API Key" Style="{StaticResource SectionLabelStyle}"/>
                                            <TextBox x:Name="DeepgramTtsApiKeyTextBox" FontSize="11" Padding="6"/>
                                            <TextBlock Text="{Binding Value, ElementName=DeepgramVolumeSlider, StringFormat='Volume: {0:0}%'}" Style="{StaticResource SectionLabelStyle}" Margin="0,8,0,4"/>
                                            <Slider x:Name="DeepgramVolumeSlider" Minimum="0" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="False" Value="100"/>
                                            <TextBlock Text="{Binding Value, ElementName=DeepgramRateSlider, StringFormat='Speed: {0:0}%'}" Style="{StaticResource SectionLabelStyle}" Margin="0,8,0,4"/>
                                            <Slider x:Name="DeepgramRateSlider" Minimum="50" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="False" Value="100"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Soniox" Foreground="White" FontSize="13" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                            <TextBlock Text="API Key" Style="{StaticResource SectionLabelStyle}"/>
                                            <TextBox x:Name="SonioxTtsApiKeyTextBox" FontSize="11" Padding="6"/>
                                            <TextBlock Text="{Binding Value, ElementName=SonioxVolumeSlider, StringFormat='Volume: {0:0}%'}" Style="{StaticResource SectionLabelStyle}" Margin="0,8,0,4"/>
                                            <Slider x:Name="SonioxVolumeSlider" Minimum="0" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="False" Value="100"/>
                                            <TextBlock Text="{Binding Value, ElementName=SonioxRateSlider, StringFormat='Speed: {0:0}%'}" Style="{StaticResource SectionLabelStyle}" Margin="0,8,0,4"/>
                                            <Slider x:Name="SonioxRateSlider" Minimum="50" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="False" Value="100"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Speechmatics" Foreground="White" FontSize="13" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                            <TextBlock Text="API Key" Style="{StaticResource SectionLabelStyle}"/>
                                            <TextBox x:Name="SpeechmaticsTtsApiKeyTextBox" FontSize="11" Padding="6"/>
                                            <TextBlock Text="{Binding Value, ElementName=SpeechmaticsVolumeSlider, StringFormat='Volume: {0:0}%'}" Style="{StaticResource SectionLabelStyle}" Margin="0,8,0,4"/>
                                            <Slider x:Name="SpeechmaticsVolumeSlider" Minimum="0" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="False" Value="100"/>
                                            <TextBlock Text="{Binding Value, ElementName=SpeechmaticsRateSlider, StringFormat='Speed: {0:0}%'}" Style="{StaticResource SectionLabelStyle}" Margin="0,8,0,4"/>
                                            <Slider x:Name="SpeechmaticsRateSlider" Minimum="50" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="False" Value="100"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Google" Foreground="White" FontSize="13" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                            <TextBlock Text="API Key" Style="{StaticResource SectionLabelStyle}"/>
                                            <TextBox x:Name="GoogleTtsApiKeyTextBox" FontSize="11" Padding="6" ToolTip="Google TTS API key"/>
                                            <TextBlock Text="{Binding Value, ElementName=GoogleVolumeSlider, StringFormat='Volume: {0:0}%'}" Style="{StaticResource SectionLabelStyle}" Margin="0,8,0,4"/>
                                            <Slider x:Name="GoogleVolumeSlider" Minimum="0" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="False" Value="100"/>
                                            <TextBlock Text="{Binding Value, ElementName=GoogleRateSlider, StringFormat='Speed: {0:0}%'}" Style="{StaticResource SectionLabelStyle}" Margin="0,8,0,4"/>
                                            <Slider x:Name="GoogleRateSlider" Minimum="50" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="False" Value="100"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Azure" Foreground="White" FontSize="13" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                            <TextBlock Text="API Key" Style="{StaticResource SectionLabelStyle}"/>
                                            <TextBox x:Name="AzureTtsApiKeyTextBox" FontSize="11" Padding="6" ToolTip="Azure TTS key"/>
                                            <TextBlock Text="{Binding Value, ElementName=AzureVolumeSlider, StringFormat='Volume: {0:0}%'}" Style="{StaticResource SectionLabelStyle}" Margin="0,8,0,4"/>
                                            <Slider x:Name="AzureVolumeSlider" Minimum="0" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="False" Value="100"/>
                                            <TextBlock Text="{Binding Value, ElementName=AzureRateSlider, StringFormat='Speed: {0:0}%'}" Style="{StaticResource SectionLabelStyle}" Margin="0,8,0,4"/>
                                            <Slider x:Name="AzureRateSlider" Minimum="50" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="False" Value="100"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="3" Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Playback Note" Foreground="White" FontSize="13" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                            <TextBlock Text="Volume and speed are stored per TTS provider and applied when that provider is selected." Foreground="#CCCCCC" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                            <TextBlock Text="Provider-specific volume/speed is independent from the TTS voice field." Foreground="#AAAAAA" FontSize="11" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </TabItem>
            </TabControl>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Save"
                        Click="SaveButton_Click"
                        Width="140"
                        Height="45"
                        Background="#007ACC"
                        Margin="0,0,15,0"/>
                <Button Content="Cancel"
                        Click="CancelButton_Click"
                        Width="140"
                        Height="45"/>
            </StackPanel>

            <TextBlock x:Name="VersionText"
                       Grid.Row="2"
                       Text="Version: 1.0.0"
                       Foreground="#666666"
                       FontSize="11"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,-15"/>
        </Grid>
    </Border>
</Window>
