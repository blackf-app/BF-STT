<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BF_STT"
        xmlns:vm="clr-namespace:BF_STT.ViewModels"
        mc:Ignorable="d"
        x:Class="BF_STT.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="BF-STT"
        Background="#1E1E1E"
        Foreground="White"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        CanResize="False"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <ContextMenu x:Key="TrayMenu">
            <MenuItem Header="Settings" Command="{Binding OpenSettingsCommand}" />
            <Separator />
            <MenuItem Header="Exit" Command="{Binding CloseCommand}" />
        </ContextMenu>

        <DataTemplate x:Key="HistoryTemplate" DataType="vm:MainViewModel">
            <Border Background="#2D2D30" CornerRadius="5" Margin="2,0,2,2" MaxHeight="250">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="5">
                        <TextBlock Text="History" Foreground="#AAAAAA" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button HorizontalAlignment="Right" Command="{Binding ClearHistoryCommand}" Padding="5,1" Background="Transparent" ToolTip.Tip="Clear All">
                            <TextBlock Text="X" FontSize="10"/>
                        </Button>
                    </Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding HistoryService.History}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#444444" BorderThickness="0,0,0,1" Padding="5,3">
                                        <Grid ColumnDefinitions="*,Auto,Auto">
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" Foreground="#888888" FontSize="9"/>
                                                <TextBlock Text="{Binding Text}" Foreground="White" FontSize="11" TextWrapping="Wrap" Margin="0,1,0,0"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" VerticalAlignment="Center"
                                                    Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).SendHistoryItemCommand}"
                                                    CommandParameter="{Binding}"
                                                    Padding="4,2" Margin="5,0,0,0"
                                                    Background="#007ACC" ToolTip.Tip="Send to last focused window">
                                                <TextBlock Text="↗" FontSize="10"/>
                                            </Button>
                                            <Button Grid.Column="2" VerticalAlignment="Center"
                                                    Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).CopyHistoryItemCommand}"
                                                    CommandParameter="{Binding}"
                                                    Padding="4,2" Margin="5,0,0,0"
                                                    Background="#3E3E42" ToolTip.Tip="Copy to Clipboard">
                                                <TextBlock Text="⎘" FontSize="10"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="3,2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#444444"/>
        </Style>
        <Style Selector="Button:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#666666"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3A3A3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Styles>

    <Grid Margin="0" Background="Transparent" PointerPressed="OnGridPointerPressed">
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Settings" Command="{Binding OpenSettingsCommand}" />
                <Separator />
                <MenuItem Header="Exit" Command="{Binding CloseCommand}" />
            </ContextMenu>
        </Grid.ContextMenu>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top History -->
        <ContentControl Grid.Row="0" Content="{Binding}" ContentTemplate="{StaticResource HistoryTemplate}"
                        IsVisible="{Binding IsHistoryTopVisible}"/>

        <!-- Controls Row -->
        <Border Grid.Row="1" Background="#1E1E1E" Padding="5,2">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="{Binding StatusText}" Foreground="#AAAAAA" FontSize="11" VerticalAlignment="Center"
                           Margin="8,0" MaxWidth="150" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding StatusText}"/>

                <Grid Width="20" Height="24" Margin="3,0" VerticalAlignment="Center" IsVisible="{Binding IsRecording}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="1.8" Height="9" Margin="0.3,0" Background="#CC3300" CornerRadius="0.9" RenderTransformOrigin="50%,50%">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleY="{Binding AudioLevel, Converter={StaticResource LevelToScaleConverter}, ConverterParameter=0.8}"/>
                            </Border.RenderTransform>
                        </Border>
                        <Border Width="2.2" Height="14" Margin="0.3,0" Background="#CC3300" CornerRadius="1.1" RenderTransformOrigin="50%,50%">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleY="{Binding AudioLevel, Converter={StaticResource LevelToScaleConverter}, ConverterParameter=1.5}"/>
                            </Border.RenderTransform>
                        </Border>
                        <Border Width="1.8" Height="9" Margin="0.3,0" Background="#CC3300" CornerRadius="0.9" RenderTransformOrigin="50%,50%">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleY="{Binding AudioLevel, Converter={StaticResource LevelToScaleConverter}, ConverterParameter=0.8}"/>
                            </Border.RenderTransform>
                        </Border>
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="3,0">
                    <ComboBox ItemsSource="{Binding ConfiguredBatchApis}" SelectedItem="{Binding BatchModeApi}"
                              ToolTip.Tip="Select Batch API Engine"
                              VerticalAlignment="Center" Margin="0,2,2,2" Width="90" Height="28" FontSize="11"/>
                    <ComboBox ItemsSource="{Binding ConfiguredStreamingApis}" SelectedItem="{Binding StreamingModeApi}"
                              ToolTip.Tip="Select Streaming API Engine"
                              VerticalAlignment="Center" Margin="2,2,0,2" Width="90" Height="28" FontSize="11"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding StartRecordingCommand}" ToolTip.Tip="Start / Cancel Recording">
                        <TextBlock Text="🎤" FontSize="14"/>
                    </Button>

                    <Button Command="{Binding StopRecordingCommand}" ToolTip.Tip="Stop &amp; Send" Background="#CC3300">
                        <TextBlock Text="■" FontSize="14"/>
                    </Button>

                    <Button Command="{Binding ResendAudioCommand}" ToolTip.Tip="Re-Send Audio" Background="#007ACC" Margin="3,2">
                        <TextBlock Text="↻" FontSize="14"/>
                    </Button>

                    <Button Command="{Binding ToggleHistoryCommand}" ToolTip.Tip="Show/Hide History" Background="#444444" Margin="3,2">
                        <TextBlock Text="≡" FontSize="14"/>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Transcript Area (Test Mode) -->
        <Border Grid.Row="2" Background="#252526" CornerRadius="5" Padding="5"
                IsVisible="{Binding IsTestMode}">
            <Grid>
                <ItemsControl ItemsSource="{Binding Providers}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="5,0">
                                <TextBlock DockPanel.Dock="Top" Text="{Binding Name}" Foreground="#AAAAAA" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                <TextBox Text="{Binding Transcript}"
                                         Background="Transparent" Foreground="White"
                                         BorderThickness="1" BorderBrush="#444444"
                                         FontSize="10" TextWrapping="Wrap" IsReadOnly="True"
                                         Height="80" Width="90"
                                         VerticalAlignment="Stretch"/>
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid Background="#AA000000" IsVisible="{Binding IsSending}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="67" Height="3" Foreground="#007ACC" Background="#333333" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Bottom History -->
        <ContentControl Grid.Row="3" Content="{Binding}" ContentTemplate="{StaticResource HistoryTemplate}"
                        IsVisible="{Binding IsHistoryBottomVisible}"/>

        <!-- Tray icon hosted via TrayIcon.Icons attached to Application -->
    </Grid>
</Window>
